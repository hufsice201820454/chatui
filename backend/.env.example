 # App
APP_NAME="ChatUI Backend"
APP_VERSION="1.0.0"
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# CORS - Next.js origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./chatui.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chatui

# LLM (OpenAI only)
DEFAULT_LLM_PROVIDER=openai
OPEN_API_KEY=sk-...
# OPENAI_API_KEY=sk-...  # 또는 OPEN_API_KEY 대신 사용

# OpenAI
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# Context window
MAX_CONTEXT_TOKENS=100000
CONTEXT_SUMMARY_THRESHOLD=0.8

# File upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
FILE_EXPIRY_DAYS=7

# S3 (optional)
USE_S3=false
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20

# Retry
MAX_RETRIES=3
RETRY_MIN_WAIT=1.0
RETRY_MAX_WAIT=60.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
